{
  "permissions": {
    "allow": [
      "WebSearch",
      "PowerShell(npm *)",
      "PowerShell(Move-Item *)",
      "PowerShell(Remove-Item *)",
      "PowerShell(npm ls *)",
      "Bash(seq 1 20)",
      "Bash(curl -s -o /tmp/l.html -w \"%{http_code}\" http://localhost:3000)",
      "Bash(break)",
      "Bash(sleep 0.5)",
      "Read(//tmp/**)",
      "Bash(xargs echo \"  hero:\")",
      "Bash(xargs echo \"  badge:\")",
      "Bash(xargs echo \"  feature finder:\")",
      "Bash(xargs echo \"  karaoke band:\")",
      "Bash(xargs echo \"  footer:\")",
      "Bash(curl -s http://localhost:3000/guitar -o /tmp/g.html -w \"GUITAR: %{http_code}\\\\n\")",
      "Bash(xargs echo \"  titulo:\")",
      "Bash(xargs echo \"  soon badges:\")",
      "Bash(xargs echo \"  link chords:\")",
      "Bash(curl -s -H 'Cookie: yk-locale=en' http://localhost:3000 -o /tmp/e.html)",
      "Bash(xargs echo \"EN hero:\")",
      "Bash(xargs echo \"EN cta:\")"
    ]
  }
}
